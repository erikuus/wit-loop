#!/usr/bin/env python3
"""Queue the existing incumbent once so the blind judge establishes its score."""

from __future__ import annotations

import secrets
import sys
from datetime import datetime, timezone

from _witlib import ROOT, WIT, atomic_json, read_text


beginning = read_text(ROOT / "input.md")
sentence = read_text(ROOT / "best.md")
if not beginning or not sentence:
    raise SystemExit("input.md and best.md must both be non-empty")
if not sentence.startswith(beginning):
    raise SystemExit("best.md does not begin with the current input")

completion = sentence[len(beginning):].strip()
if not completion:
    raise SystemExit("best.md has no completion after the current input")

if len(sys.argv) > 2 or (len(sys.argv) == 2 and sys.argv[1] != "--priority"):
    raise SystemExit("usage: seed-existing-best [--priority]")

stamp = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%S%fZ")
prefix = "00000000T000000000000Z" if "--priority" in sys.argv else stamp
candidate_id = f"{prefix}-seed-{secrets.token_hex(4)}"
candidate = {
    "id": candidate_id,
    "input": beginning,
    "completion": completion,
    "sentence": sentence,
    "seeded_incumbent": True,
}
atomic_json(WIT / "pending" / f"{candidate_id}.json", candidate)
print("Existing best queued for blind evaluation.")
