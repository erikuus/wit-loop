def main() -> None:
    rows = load_rows()
    metrics = build_metrics(rows)

    HTML_DIR.mkdir(parents=True, exist_ok=True)
    STYLE_DIR.mkdir(parents=True, exist_ok=True)

    (ROOT / "index.html").write_text(render_index(), encoding="utf-8")
    (HTML_DIR / "wit-loop-en.html").write_text(render_page("en", rows, metrics), encoding="utf-8")
    (HTML_DIR / "wit-loop-et.html").write_text(render_page("et", rows, metrics), encoding="utf-8")
    (STYLE_DIR / "site.css").write_text(render_styles(), encoding="utf-8")


if __name__ == "__main__":
    main()
