def read_text(path: Path) -> str:
    return path.read_text(encoding="utf-8").strip()


def load_rows() -> list[dict]:
    rows = []
    for path in sorted(glob.glob(str(ROOT / ".wit" / "evaluations" / "*.json"))):
        with open(path, encoding="utf-8") as handle:
            payload = json.load(handle)
        evaluation = payload["evaluation"]
        candidate = payload["candidate"]
        decision = payload["decision"]
        rows.append(
            {
                "id": candidate["id"],
                "date": payload["finalized_at"][:10],
                "completion": candidate["completion"],
                "sentence": candidate["sentence"],
                "score": evaluation["final_score"],
                "outcome": decision["outcome"],
                "reason": decision["reason"],
                "raw_scores": evaluation["raw_scores"],
            }
        )
    return rows


def month_name(month_index: int, lang: str) -> str:
    months = {
        "en": [
            "January",
            "February",
            "March",
            "April",
            "May",
            "June",
            "July",
            "August",
            "September",
            "October",
            "November",
            "December",
        ],
        "et": [
            "jaanuar",
            "veebruar",
            "marts",
            "aprill",
            "mai",
            "juuni",
            "juuli",
            "august",
            "september",
            "oktoober",
            "november",
            "detsember",
        ],
    }
    return months[lang][month_index - 1]


def human_date(date_text: str, lang: str) -> str:
    date_obj = datetime.strptime(date_text, "%Y-%m-%d")
    if lang == "et":
        return f"{date_obj.day}. {month_name(date_obj.month, lang)} {date_obj.year}"
    return f"{month_name(date_obj.month, lang)} {date_obj.day}, {date_obj.year}"


def render_criteria_cards(lang: str) -> str:
    parts = []
    for _, labels in CRITERIA:
        localized = labels[lang]
        if not localized:
            continue
        title, body = localized
        parts.append(
            "\n".join(
                [
                    '<article class="criteria-item">',
                    '  <p class="mini-dot" aria-hidden="true"></p>',
                    '  <div class="criteria-copy">',
                    f"    <h3>{html.escape(title)}</h3>",
                    f"    <p>{html.escape(body)}</p>",
                    "  </div>",
                    "</article>",
                ]
            )
        )
    return "\n".join(parts)


def render_stats(copy: dict, metrics: dict) -> str:
    parts = []
    for label, template in copy["stats"]:
        parts.append(
            "\n".join(
                [
                    '<div class="stat-item">',
                    f"  <div class=\"stat-value\">{html.escape(template.format(**metrics))}</div>",
                    f"  <div class=\"stat-label\">{html.escape(label)}</div>",
                    "</div>",
                ]
            )
        )
    return "\n".join(parts)


def render_steps(steps: list[tuple[str, str]]) -> str:
    parts = []
    for title, body in steps:
        parts.append(
            "\n".join(
                [
                    "<li>",
                    f"  <p class=\"step-title\">{html.escape(title)}</p>",
                    f"  <p>{html.escape(body)}</p>",
                    "</li>",
                ]
            )
        )
    return "\n".join(parts)


def normalize_completion(text: str) -> str:
    return re.sub(r"[\W_]+$", "", text.strip().lower())


def unique_rows_for_table(rows: list[dict]) -> list[dict]:
    chosen: dict[str, dict] = {}
    for row in sorted(rows, key=lambda item: (-item["score"], item["date"], item["id"])):
        normalized = normalize_completion(row["completion"])
        if normalized not in chosen:
            chosen[normalized] = row
    return list(chosen.values())


def render_table_rows(rows: list[dict], lang: str, copy: dict) -> str:
    parts = []
    for row in unique_rows_for_table(rows):
        parts.append(
            "\n".join(
                [
                    "      <tr>",
                    f"        <td><strong>{row['score']}</strong></td>",
                    f"        <td class=\"ending-cell\"><span>{html.escape(row['completion'])}</span></td>",
                    "      </tr>",
                ]
            )
        )
    return "\n".join(parts)


def build_metrics(rows: list[dict]) -> dict:
    with open(ROOT / ".wit" / "state.json", encoding="utf-8") as handle:
        state = json.load(handle)
    scored_count = len(rows)
    pending_count = len(glob.glob(str(ROOT / ".wit" / "pending" / "*.json")))
    dates = [row["date"] for row in rows]
    return {
        "input_text": read_text(ROOT / "input.md"),
        "best_text": read_text(ROOT / "best.md"),
        "best_score": state["best_score"],
        "scored_count": scored_count,
        "winner_count": sum(1 for row in rows if row["outcome"] == "winner"),
        "pending_count": pending_count,
        "average_score": f"{statistics.mean(row['score'] for row in rows):.1f}",
        "first_date_en": human_date(min(dates), "en"),
        "last_date_en": human_date(max(dates), "en"),
        "first_date_et": human_date(min(dates), "et"),
        "last_date_et": human_date(max(dates), "et"),
        "snapshot_date_en": human_date(datetime.now().strftime("%Y-%m-%d"), "en"),
        "snapshot_date_et": human_date(datetime.now().strftime("%Y-%m-%d"), "et"),
    }


def render_page(lang: str, rows: list[dict], metrics: dict) -> str:
    copy = COPY[lang]
    first_date = metrics[f"first_date_{lang}"]
    last_date = metrics[f"last_date_{lang}"]
    table_header = copy["table_headers"]
    hero_source_html = f'\n      <p class="hero-source">{html.escape(copy["hero_source"])}</p>' if copy.get("hero_source") else ""
    results_note_html = f'\n        <p class="table-note">{html.escape(copy["results_note"])}</p>' if copy["results_note"] else ""
    origin_intro_html = f'\n        <p>{html.escape(copy["origin_intro"])}</p>' if copy["origin_intro"] else ""
    origin_p3_html = f'\n        <p>{html.escape(copy["origin_p3"])}</p>' if copy["origin_p3"] else ""

    return f"""<!DOCTYPE html>
<html lang="{copy['lang']}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{html.escape(copy['title'])}</title>
  <meta name="description" content="{html.escape(copy['subtitle'])}">
  <link rel="icon" href="data:,">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="../assets/styles/site.css?v=20260627a">
</head>
<body>
  <header class="page-header">
    <a class="lang-switch" href="{html.escape(copy['lang_switch_href'])}" lang="{html.escape(copy['lang_switch_href'][-7:-5])}">{html.escape(copy['lang_switch_label'])}</a>
  </header>

  <main class="content-shell reader-page">
    <section class="narrative-hero">
      <h1>{html.escape(copy['hero_title'])}</h1>
      <p class="hero-lede">{html.escape(copy['hero_lede'])}</p>
      <p class="sentence-fragment"><span>{html.escape(copy['fragment_label'])}</span>{html.escape(metrics['input_text'])} ...</p>{hero_source_html}
    </section>

    <section class="flow-section plain-flow-section">
      <div class="section-copy">
        <h2>{html.escape(copy['criteria_label'])}</h2>
        <p>{html.escape(copy['criteria_intro'])}</p>
        <div class="criteria-list">
          {render_criteria_cards(lang).replace(chr(10), chr(10) + "          ")}
        </div>
      </div>
    </section>

    <section class="flow-section plain-flow-section">
      <div class="section-copy">
        <h2>{html.escape(copy['process_label'])}</h2>
        <p>{html.escape(copy['process_intro'])}</p>
        <ol class="step-list">
          {render_steps(copy['steps']).replace(chr(10), chr(10) + "          ")}
        </ol>
      </div>
    </section>

    <section class="flow-section results-section">
      <p class="section-marker" aria-hidden="true"></p>
      <div class="section-copy">
        <h2>{html.escape(copy['results_label'])}</h2>
        <p>{copy['results_intro'].format(first_date=html.escape(first_date), last_date=html.escape(last_date), scored_count=metrics['scored_count'], winner_count=metrics['winner_count'], pending_count=metrics['pending_count'])}</p>{results_note_html}
        <div class="table-shell">
          <table>
            <thead>
              <tr>
                <th>{html.escape(table_header['score'])}</th>
                <th>{html.escape(table_header['ending'])}</th>
              </tr>
            </thead>
            <tbody>
{render_table_rows(rows, lang, copy)}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section class="flow-section verdict-section">
      <p class="section-marker" aria-hidden="true"></p>
      <div class="section-copy">
        <h2>{html.escape(copy['result_label'])}</h2>
        <p>{copy['ai_result_intro'].format(scored_count=metrics['scored_count'])}</p>
        <blockquote class="result-quote quote-panel">{html.escape(metrics['best_text'])}</blockquote>
        <p>{copy['ai_result_note'].format(best_score=metrics['best_score'])}</p>
      </div>
    </section>

    <section class="flow-section closing-section">
      <p class="section-marker" aria-hidden="true"></p>
      <div class="section-copy">
        <h2>{html.escape(copy['origin_label'])}</h2>
{origin_intro_html}
        <blockquote class="origin-quote quote-panel">{html.escape(copy['origin_line'])}</blockquote>
        <p>{html.escape(copy['origin_p1'])}</p>
        <p>{html.escape(copy['origin_p2'])}</p>
{origin_p3_html}
      </div>
    </section>
  </main>
</body>
</html>
"""


