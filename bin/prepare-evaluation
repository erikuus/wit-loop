#!/usr/bin/env python3
"""Move the oldest candidate into the isolated judge workspace."""

from __future__ import annotations

import fcntl
import os

from _witlib import ROOT, WIT, atomic_text


WIT.mkdir(parents=True, exist_ok=True)
lock_path = WIT / "queue.lock"
with lock_path.open("a+") as lock:
    fcntl.flock(lock, fcntl.LOCK_EX)
    judge = ROOT / "judge"
    for abandoned in (judge / "candidate.json", judge / "criteria.md", judge / "evaluation.json"):
        if abandoned.exists():
            abandoned.unlink()

    pending = sorted((WIT / "pending").glob("*.json"))
    if not pending:
        raise SystemExit("No pending candidate.")
    os.replace(pending[0], judge / "candidate.json")
    atomic_text(judge / "criteria.md", (ROOT / "criteria.md").read_text(encoding="utf-8"))
print("Evaluation prepared.")
